{% schema %}
{
  "name": "Video Hero",
  "tag": "section",
  "class": "video-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury isn’t a destination. It’s how you get there"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "info": "Link for the 'View Collection' button."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View Collection"
    }
  ],
  "presets": [
    {
      "name": "Video Hero"
    }
  ]
}
{% endschema %}

<style>
.video-hero-section {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.video-hero-section video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}

.video-gradient-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    rgba(0, 0, 0, 0.5),
    rgba(0, 0, 0, 0.35),
    rgba(0, 0, 0, 0.5)
  );
  z-index: 2;
}

.video-hero-overlay {
  position: absolute;
  bottom: 40px;
  right: 40px;
  z-index: 3;
  max-width: 500px;
  padding: 20px;
  text-align: right;
  color: white;
  font-family: 'Cormorant Garamond', serif;
  font-weight: 700;
}

.video-hero-overlay p {
  margin: 0 0 15px 0;
  font-size: 2.8rem;
  line-height: 1.3;
}

.video-hero-overlay p.uppercase {
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 2.4rem;
}

.hero-button {
  display: inline-block;
  padding: 16px 36px;
  background-color: white;
  color: black;
  border: none;
  border-radius: 999px;
  font-family: 'Montserrat', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  letter-spacing: 0.05em;
  transition: all 0.3s ease;
  cursor: pointer;
}

.hero-button:hover {
  background-color: black;
  color: white;
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(0,0,0,0.3);
}

@media (max-width: 768px) {
  .video-hero-overlay {
    bottom: 30px;
    right: 30px;
    max-width: 90%;
  }
  .video-hero-overlay p {
    font-size: 2rem;
  }
  .video-hero-overlay p.uppercase {
    font-size: 1.8rem;
  }
  .hero-button {
    font-size: 0.9rem;
    padding: 12px 28px;
  }
}

@media (max-width: 480px) {
  .video-hero-overlay {
    bottom: 20px;
    right: 20px;
    max-width: 90%;
  }
  .video-hero-overlay p {
    font-size: 1.6rem;
  }
  .video-hero-overlay p.uppercase {
    font-size: 1.4rem;
  }
  .hero-button {
    width: 100%;
    padding: 12px 0;
    text-align: center;
  }
}
</style>

<section class="video-hero-section">
  <video autoplay muted loop playsinline preload="auto">
    <source src="https://cdn.shopify.com/videos/c/o/v/3c19ef49c1c94c2f92fb6a8d49f90065.mp4" type="video/mp4">
    Your browser does not support the video tag.
  </video>

  <div class="video-gradient-overlay"></div>

  <div class="video-hero-overlay">
    {% if section.settings.heading != blank %}
      {% assign sentences = section.settings.heading | split: '.' %}
      {% for sentence in sentences %}
        {% assign clean = sentence | strip %}
        {% if clean != blank %}
          {% if forloop.index == 2 %}
            <p class="uppercase">{{ clean }}.</p>
          {% else %}
            <p>{{ clean }}.</p>
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if section.settings.button_link != blank and section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="hero-button" aria-label="{{ section.settings.button_text }}">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>




