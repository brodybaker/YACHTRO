{% schema %}
{
  "name": "Luxury Yachts Section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Luxury Yachts for Sale"
    },
    {
      "type": "collection",
      "id": "yacht_collection",
      "label": "Select Yacht Collection"
    },
    {
      "type": "text",
      "id": "default_location",
      "label": "Default Location (if metafield is missing)",
      "default": "Location Not Specified"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show Filters",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Luxury Yachts Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>
  .luxury-yachts-section {
    padding: 40px 20px;
    background-color: #f8f9fa;
  }
  .luxury-yachts-section h2 {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a2a44;
    margin-bottom: 30px;
    text-transform: uppercase;
  }
  .yachts-container {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    gap: 20px;
  }
  .yachts-filter-sidebar {
    width: 250px;
    flex-shrink: 0;
  }
  .yachts-filter-sidebar h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1a2a44;
    margin-bottom: 15px;
  }
  .yachts-filter-group {
    margin-bottom: 20px;
  }
  .yachts-filter-group label {
    display: block;
    font-size: 1rem;
    color: #1a2a44;
    margin-bottom: 5px;
    font-weight: 500;
  }
  .yachts-filter-group input[type="checkbox"] {
    margin-right: 8px;
  }
  .yachts-filter-group .filter-value {
    margin-bottom: 5px;
    font-size: 0.9rem;
    color: #666;
  }
  .yachts-filter-group .filter-count {
    color: #999;
    font-size: 0.8rem;
  }
  .yachts-filter-group .filter-range {
    margin-top: 10px;
  }
  .yachts-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }
  .yacht-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .yacht-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
  }
  .yacht-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .yacht-info {
    padding: 20px;
  }
  .yacht-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1a2a44;
    margin: 0 0 10px;
  }
  .yacht-price {
    font-size: 1.2rem;
    color: #e74c3c;
    margin: 0 0 10px;
  }
  .yacht-location {
    font-size: 1rem;
    color: #666;
    margin: 0 0 10px;
    font-style: italic;
  }
  .yacht-description {
    font-size: 0.9rem;
    color: #666;
    margin: 0 0 15px;
    line-height: 1.4;
  }
  .yacht-button {
    display: inline-block;
    padding: 10px 20px;
    background-color: #1a2a44;
    color: #fff;
    text-align: center;
    text-decoration: none;
    border-radius: 5px;
    font-size: 1rem;
    transition: background-color 0.3s ease;
  }
  .yacht-button:hover {
    background-color: #2c3e50;
  }
  .clear-filters {
    display: inline-block;
    margin-top: 10px;
    color: #e74c3c;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .clear-filters:hover {
    text-decoration: underline;
  }
  .pagination {
    text-align: center;
    margin-top: 20px;
  }
  .pagination a, .pagination span {
    margin: 0 5px;
    text-decoration: none;
    color: #1a2a44;
  }
  .pagination a:hover {
    text-decoration: underline;
  }
  .pagination .current {
    font-weight: bold;
  }
  @media (max-width: 768px) {
    .yachts-container {
      flex-direction: column;
    }
    .yachts-filter-sidebar {
      width: 100%;
    }
    .yachts-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
    .luxury-yachts-section h2 {
      font-size: 2rem;
    }
  }
</style>

{% assign collection = collections[section.settings.yacht_collection] %}
<section class="luxury-yachts-section">
  <h2>{{ section.settings.section_title }}</h2>
  <div class="yachts-container">
    {% if section.settings.show_filters %}
      <div class="yachts-filter-sidebar">
        <h3>Filter Yachts</h3>
        {% render 'collection-filters' %}
      </div>
    {% endif %}
    <div class="yachts-grid">
      {% paginate collection.products by 12 %}
        {% if collection.products.size > 0 %}
          {% for product in collection.products %}
            <div class="yacht-card">
              {% if product.featured_image %}
                <img class="yacht-image" src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title | escape }}">
              {% else %}
                <img class="yacht-image" src="{{ 'placeholder-yacht.jpg' | asset_url }}" alt="Placeholder Image">
              {% endif %}
              <div class="yacht-info">
                <h3 class="yacht-title">{{ product.title }}</h3>
                <p class="yacht-price">{{ product.price | money }}</p>
                {% assign location_json = product.metafields.custom.location_json | json_parse %}
                <p class="yacht-location">
                  {% if location_json and location_json.city and location_json.state %}
                    {{ location_json.city }}, {{ location_json.state }}
                  {% else %}
                    {{ section.settings.default_location }}
                  {% endif %}
                </p>
                <p class="yacht-description">{{ product.description | strip_html | truncate: 100 }}</p>
                <a href="{{ product.url }}" class="yacht-button">View Details</a>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <p>No yachts match the selected filters.</p>
        {% endif %}
        {% if paginate.pages > 1 %}
          <div class="pagination">
            {% if paginate.previous.is_link %}
              <a href="{{ paginate.previous.url }}">Previous</a>
            {% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {% else %}
                <span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>
              {% endif %}
            {% endfor %}
            {% if paginate.next.is_link %}
              <a href="{{ paginate.next.url }}">Next</a>
            {% endif %}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</section>