{% comment %}
  SEO-Optimized Homepage Template for Yacht & Boat Sales
  Designed for maximum search engine visibility and conversion
{% endcomment %}

<!-- Hero Section with SEO-Optimized Content -->
<section class="hero-yacht-sales" itemscope itemtype="https://schema.org/LocalBusiness">
  <div class="hero-content">
    <h1 class="hero-title">
      <span itemprop="name">{{ settings.seo_business_name | default: shop.name }}</span> - 
      Premier Luxury Yacht & Boat Sales
    </h1>
    <p class="hero-subtitle" itemprop="description">
      {{ settings.seo_business_description | default: "Discover the world's finest collection of luxury yachts, motor yachts, sailing yachts, and superyachts. Expert yacht brokers, comprehensive marine services, and unparalleled customer experience." }}
    </p>
    <div class="hero-cta">
      <a href="/collections/all" class="btn btn-primary" aria-label="Browse Our Yacht Collection">
        Browse Our Yacht Collection
      </a>
      <a href="/pages/contact" class="btn btn-secondary" aria-label="Contact Our Yacht Experts">
        Contact Our Experts
      </a>
    </div>
  </div>
  
  <!-- Trust Signals -->
  <div class="trust-signals">
    <div class="trust-item">
      <strong>25+ Years</strong>
      <span>Marine Industry Experience</span>
    </div>
    <div class="trust-item">
      <strong>500+</strong>
      <span>Yachts Sold</span>
    </div>
    <div class="trust-item">
      <strong>$2B+</strong>
      <span>In Yacht Sales</span>
    </div>
  </div>
</section>

<!-- Featured Yacht Categories -->
<section class="yacht-categories" aria-labelledby="categories-title">
  <div class="container">
    <h2 id="categories-title" class="section-title">
      Luxury Yachts & Boats for Sale
    </h2>
    <p class="section-subtitle">
      Explore our extensive collection of premium vessels from the world's leading yacht manufacturers
    </p>
    
    <div class="category-grid">
      {% assign yacht_collections = collections | where: 'handle', 'motor-yachts', 'sailing-yachts', 'superyachts', 'sport-fishing' %}
      {% for collection in yacht_collections limit: 4 %}
        <article class="category-card" itemscope itemtype="https://schema.org/Product">
          <a href="{{ collection.url }}" class="category-link" aria-label="Browse {{ collection.title }}">
            {% if collection.featured_image %}
              <img 
                src="{{ collection.featured_image | image_url: width: 600, height: 400 }}"
                alt="{{ collection.title }} - {{ collection.description | strip_html | truncate: 100 }}"
                width="600"
                height="400"
                loading="lazy"
                itemprop="image"
              />
            {% endif %}
            <div class="category-content">
              <h3 class="category-title" itemprop="name">{{ collection.title }}</h3>
              <p class="category-description" itemprop="description">
                {{ collection.description | strip_html | truncate: 120 }}
              </p>
              <div class="category-meta">
                <span class="product-count">{{ collection.products_count }} Available</span>
                <span class="price-range">Starting from ${{ collection.products.first.price | money_without_currency }}</span>
              </div>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Featured Yachts -->
<section class="featured-yachts" aria-labelledby="featured-title">
  <div class="container">
    <h2 id="featured-title" class="section-title">
      Featured Luxury Yachts
    </h2>
    <p class="section-subtitle">
      Hand-selected premium vessels representing the pinnacle of yacht design and craftsmanship
    </p>
    
    <div class="yacht-grid">
      {% assign featured_products = collections.featured.products | default: collections.all.products %}
      {% for product in featured_products limit: 6 %}
        <article class="yacht-card" itemscope itemtype="https://schema.org/Product">
          <a href="{{ product.url }}" class="yacht-link" aria-label="View {{ product.title }}">
            {% if product.featured_image %}
              <div class="yacht-image">
                <img 
                  src="{{ product.featured_image | image_url: width: 500, height: 350 }}"
                  alt="{{ product.title }} - {{ product.vendor }} Yacht for Sale"
                  width="500"
                  height="350"
                  loading="lazy"
                  itemprop="image"
                />
                {% if product.compare_at_price > product.price %}
                  <span class="sale-badge">Special Offer</span>
                {% endif %}
              </div>
            {% endif %}
            
            <div class="yacht-content">
              <div class="yacht-header">
                <h3 class="yacht-title" itemprop="name">{{ product.title }}</h3>
                <span class="yacht-brand" itemprop="brand">{{ product.vendor }}</span>
              </div>
              
              <p class="yacht-description" itemprop="description">
                {{ product.description | strip_html | truncate: 100 }}
              </p>
              
              <div class="yacht-specs">
                {% if product.metafields.specs.length %}
                  <span class="spec">{{ product.metafields.specs.length }}ft</span>
                {% endif %}
                {% if product.metafields.specs.year %}
                  <span class="spec">{{ product.metafields.specs.year }}</span>
                {% endif %}
                {% if product.metafields.specs.guests %}
                  <span class="spec">{{ product.metafields.specs.guests }} Guests</span>
                {% endif %}
              </div>
              
              <div class="yacht-pricing" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                {% if product.compare_at_price > product.price %}
                  <span class="original-price">${{ product.compare_at_price | money_without_currency }}</span>
                {% endif %}
                <span class="current-price" itemprop="price" content="{{ product.price | money_without_currency }}">
                  ${{ product.price | money_without_currency }}
                </span>
                <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
                <meta itemprop="availability" content="{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
              </div>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
    
    <div class="section-cta">
      <a href="/collections/all" class="btn btn-outline" aria-label="View All Yachts for Sale">
        View All Yachts for Sale
      </a>
    </div>
  </div>
</section>

<!-- Services Section -->
<section class="yacht-services" aria-labelledby="services-title">
  <div class="container">
    <h2 id="services-title" class="section-title">
      Comprehensive Yacht Services
    </h2>
    <p class="section-subtitle">
      From purchase to maintenance, we provide complete yacht ownership solutions
    </p>
    
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <path d="M24 4L6 14V34L24 44L42 34V14L24 4Z" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="service-title">Yacht Brokerage</h3>
        <p class="service-description">
          Expert yacht brokerage services with comprehensive market analysis, professional marketing, and seamless transaction management.
        </p>
      </div>
      
      <div class="service-card">
        <div class="service-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <path d="M12 8V40L24 32L36 40V8H12Z" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="service-title">Marine Financing</h3>
        <p class="service-description">
          Competitive marine financing options with leading lenders, flexible terms, and expert guidance through the financing process.
        </p>
      </div>
      
      <div class="service-card">
        <div class="service-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <path d="M24 12C18.48 12 14 16.48 14 22C14 27.52 18.48 32 24 32C29.52 32 34 27.52 34 22C34 16.48 29.52 12 24 12Z" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="service-title">Yacht Management</h3>
        <p class="service-description">
          Complete yacht management services including maintenance, crew management, charter management, and administrative support.
        </p>
      </div>
      
      <div class="service-card">
        <div class="service-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <path d="M8 24L16 16L24 24L32 16L40 24" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="service-title">Trade-In Services</h3>
        <p class="service-description">
          Professional yacht appraisals and trade-in services to help you upgrade to your dream vessel with maximum value.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
