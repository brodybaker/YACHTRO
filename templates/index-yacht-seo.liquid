        <div class="testimonial-content">
          <p itemprop="reviewBody">
            "Exceptional service from start to finish. The team's expertise in luxury yachts is unmatched. They helped us find the perfect vessel and handled every detail of the transaction professionally."
          </p>
        </div>
        <footer class="testimonial-author">
          <cite itemprop="author" itemscope itemtype="https://schema.org/Person">
            <span itemprop="name">Michael Thompson</span>
          </cite>
          <span class="author-title">Yacht Owner</span>
          <div class="rating" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
            <meta itemprop="ratingValue" content="5">
            <meta itemprop="bestRating" content="5">
            ★★★★★
          </div>
        </footer>
      </blockquote>
      
      <blockquote class="testimonial" itemscope itemtype="https://schema.org/Review">
        <div class="testimonial-content">
          <p itemprop="reviewBody">
            "Outstanding yacht brokerage experience. Their knowledge of the market and attention to detail made the purchase process smooth and stress-free. Highly recommended!"
          </p>
        </div>
        <footer class="testimonial-author">
          <cite itemprop="author" itemscope itemtype="https://schema.org/Person">
            <span itemprop="name">Sarah Williams</span>
          </cite>
          <span class="author-title">First-time Yacht Buyer</span>
          <div class="rating" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
            <meta itemprop="ratingValue" content="5">
            <meta itemprop="bestRating" content="5">
            ★★★★★
          </div>
        </footer>
      </blockquote>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="faq-section" aria-labelledby="faq-title">
  <div class="container">
    <h2 id="faq-title" class="section-title">
      Frequently Asked Questions
    </h2>
    
    <div class="faq-grid">
      <details class="faq-item" itemscope itemtype="https://schema.org/Question">
        <summary class="faq-question" itemprop="name">
          What types of yachts do you specialize in?
        </summary>
        <div class="faq-answer" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
          <p itemprop="text">
            We specialize in luxury motor yachts, sailing yachts, superyachts, sport fishing boats, and custom-built vessels from renowned manufacturers like Azimut, Ferretti, Sunseeker, Princess, and many others.
          </p>
        </div>
      </details>
      
      <details class="faq-item" itemscope itemtype="https://schema.org/Question">
        <summary class="faq-question" itemprop="name">
          Do you offer yacht financing options?
        </summary>
        <div class="faq-answer" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
          <p itemprop="text">
            Yes, we work with leading marine lenders to provide competitive financing options for qualified buyers. Our finance team can help structure loans for both new and pre-owned vessels with flexible terms and competitive rates.
          </p>
        </div>
      </details>
      
      <details class="faq-item" itemscope itemtype="https://schema.org/Question">
        <summary class="faq-question" itemprop="name">
          What is included in your yacht brokerage services?
        </summary>
        <div class="faq-answer" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
          <p itemprop="text">
            Our comprehensive brokerage services include market analysis, professional photography and marketing, sea trials coordination, marine surveys, documentation assistance, and complete closing support to ensure a smooth transaction.
          </p>
        </div>
      </details>
      
      <details class="faq-item" itemscope itemtype="https://schema.org/Question">
        <summary class="faq-question" itemprop="name">
          Do you accept yacht trade-ins?
        </summary>
        <div class="faq-answer" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
          <p itemprop="text">
            Absolutely! We accept trade-ins and provide professional yacht appraisals to determine fair market value. Our trade-in program makes it easy to upgrade to your next dream vessel while maximizing the value of your current yacht.
          </p>
        </div>
      </details>
    </div>
  </div>
</section>

<!-- Contact CTA -->
<section class="contact-cta">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">
        Ready to Find Your Dream Yacht?
      </h2>
      <p class="cta-subtitle">
        Contact our expert yacht brokers today for personalized service and exclusive access to the finest vessels on the market.
      </p>
      <div class="cta-buttons">
        <a href="/pages/contact" class="btn btn-primary" aria-label="Contact Our Yacht Experts">
          Contact Our Experts
        </a>
        <a href="tel:{{ settings.seo_phone_number }}" class="btn btn-secondary" aria-label="Call {{ settings.seo_phone_number }}">
          Call {{ settings.seo_phone_number }}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Structured Data for Local Business -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "{{ settings.seo_business_name | default: shop.name }}",
  "image": "{% if settings.logo %}{{ settings.logo | image_url: width: 800 }}{% endif %}",
  "description": "{{ settings.seo_business_description | default: shop.description }}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{ settings.seo_address_street }}",
    "addressLocality": "{{ settings.seo_address_city }}",
    "addressRegion": "{{ settings.seo_address_state }}",
    "postalCode": "{{ settings.seo_address_zip }}",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ settings.seo_latitude }},
    "longitude": {{ settings.seo_longitude }}
  },
  "url": "{{ shop.url }}",
  "telephone": "{{ settings.seo_phone_number }}",
  "openingHours": "{{ settings.seo_opening_hours }}",
  "priceRange": "$$$"
}
</script>