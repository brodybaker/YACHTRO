{% comment %}
  Section Padding Snippet
  Generates consistent padding styles for sections
  
  Accepts:
  - section: {Object} Section object
  - class_prefix: {String} CSS class prefix (optional)
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign class_prefix = class_prefix | default: 'section'
  assign padding_top = section.settings.padding_top | default: 36
  assign padding_bottom = section.settings.padding_bottom | default: 36
  assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom
-%}

{%- style -%}
  .{{ class_prefix }}-{{ section_id }}-padding {
    padding-top: {{ padding_top_mobile | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom_mobile | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .{{ class_prefix }}-{{ section_id }}-padding {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
    }
  }
{%- endstyle -%}